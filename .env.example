# ──────────────────────────────────────────────
# BASE DE DONNÉES (Supabase PostgreSQL)
# ──────────────────────────────────────────────
# Utilisez le port 6543 (transaction mode PgBouncer) pour le runtime
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&sslmode=require
# Utilisez le port 5432 (session mode) pour les migrations Prisma
DIRECT_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?sslmode=require

# ──────────────────────────────────────────────
# NEXTAUTH
# ──────────────────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-min-32-chars

# ──────────────────────────────────────────────
# CRON JOBS (Vercel Cron)
# ──────────────────────────────────────────────
# Générez un secret fort : openssl rand -hex 32
# Ajoutez-le dans Vercel > Settings > Environment Variables
CRON_SECRET=your-cron-secret-min-32-chars
# En local : http://localhost:3000
# Sur Railway : https://votre-app.up.railway.app
NEXTAUTH_URL=https://votre-app.up.railway.app
NEXT_PUBLIC_SITE_URL=https://votre-app.up.railway.app

# ──────────────────────────────────────────────
# EMAIL (Gmail App Password)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tifuzzied@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Tef-Lab <tifuzzied@gmail.com>"

# ──────────────────────────────────────────────
# ADMIN
# ──────────────────────────────────────────────
ADMIN_EMAIL=tifuzzied@gmail.com
ADMIN_WHATSAPP=237683008287

# ──────────────────────────────────────────────
# ANTHROPIC (Correction IA EE/EO)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# INWORLD (TTS voix française pour EO)
# Modèle : inworld-tts-mini-1.5
# Voix FR : Alain, Hélène, Mathieu, Étienne
# ──────────────────────────────────────────────
INWORLD_API_KEY=your-inworld-api-key-base64
# Router ID pour la génération de dialogues (Q1-4 conversations, Q23-28 interviews)
# Disponible dans votre dashboard Inworld > Character Graph > Router
INWORLD_ROUTER_ID=your-inworld-router-id

# ──────────────────────────────────────────────
# SUPABASE STORAGE (Upload images/audio)
# Créez un bucket public "tef-lab-media" dans Supabase > Storage
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ──────────────────────────────────────────────
# NOTCHPAY (Paiement XAF)
# ──────────────────────────────────────────────
NOTCHPAY_PUBLIC_KEY=pk_test.apwM14UInxS0r2MG72hToccDchGiq9DTLZWMTHq0Q9dqIAx4bUFX8dhU24BdOAbWHQkYSRpS7LuateMEeOZXN7RqMZBGVOdw0Qf5VT6bcOd9tqBtD8Kiqhn9y5Fsc
# Webhook hash — à récupérer dans votre dashboard NotchPay
NOTCHPAY_WEBHOOK_HASH=your-notchpay-webhook-hash

# ──────────────────────────────────────────────
# PAYPAL (Paiement USD)
# ──────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=live
